# Fake Google Environment Configuration
# Copy this file to .env and configure your values

# Database Configuration
DATABASE_URL=postgresql://<user>:<password>@shared-postgres-multitenant:5432/fake-google

# Google APIs (Optional - app works without these but with limited functionality)
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_custom_search_engine_id_here

# Google Gemini AI (for AI-powered ad generation)
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

# Google Analytics (optional)
NEXT_PUBLIC_GA_TRACKING_ID=G-XXXXXXXXXX
